# Copy to .env and fill in values. Never commit .env to git.

ENV=development

# SECURITY – generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

# DATABASE
# SQLite (default): sqlite+aiosqlite:///./trainmaster.db
# PostgreSQL:       postgresql+asyncpg://user:password@host:5432/trainmaster
DATABASE_URL=sqlite+aiosqlite:///./trainmaster.db

# CORS
# Comma-separated origins. Example: https://trainmaster.app,http://localhost:5173
CORS_ORIGINS=["http://localhost:5173"]

# EMAIL (Gmail example)
# 1. Enable 2FA on Gmail
# 2. Go to myaccount.google.com/apppasswords and generate an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@trainmaster.app

# AI VALIDATION
# "local"       – uses sentence-transformers locally (no API key needed)
# "huggingface" – uses HuggingFace Inference API (requires key below)
VALIDATION_BACKEND=local
HUGGINGFACE_API_KEY=

# Thresholds (tweak for your subject domain)
FUZZY_THRESHOLD=80
SEMANTIC_THRESHOLD=0.75
